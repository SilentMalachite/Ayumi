#!/bin/sh
set -e

echo ""
echo "Ayumi を起動しています..."
echo ""

# --- ここを編集してください ---
# SECRET_KEY_BASE は mix phx.gen.secret で生成できます（64文字以上）
SECRET_KEY_BASE="CHANGE_ME_run_mix_phx_gen_secret_to_generate"
# ---------------------------------

if [ "$SECRET_KEY_BASE" = "CHANGE_ME_run_mix_phx_gen_secret_to_generate" ]; then
    echo "[エラー] start.sh を編集して SECRET_KEY_BASE を設定してください。"
    echo "生成コマンド: mix phx.gen.secret"
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

export SECRET_KEY_BASE
export DATABASE_PATH="${SCRIPT_DIR}/data/ayumi.db"
export PHX_SERVER=true
export PHX_HOST=localhost
export PORT=4000

echo "サーバを起動します: http://localhost:${PORT}"
echo "LAN 上の他の端末からは http://（このMacのIPアドレス）:${PORT} でアクセスできます。"
echo "停止するには Ctrl+C を押してください。"
echo ""

exec "${SCRIPT_DIR}/_build/prod/rel/ayumi/bin/server"
